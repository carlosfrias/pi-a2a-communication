/**
 * A2A Gateway Configuration
 *
 * Bridges A2A protocol (external) ↔ coms-net (internal fleet).
 * This config file defines how the A2A gateway translates between the two protocols.
 *
 * Phase 1: A2A Gateway alongside coms-net (additive, zero fleet changes)
 */

{
  "gateway": {
    "name": "pi-a2a-gateway",
    "version": "0.1.0-alpha.1",
    "description": "A2A gateway for pi fleet — bridges A2A protocol to coms-net",

    // A2A server configuration (exposed to external A2A agents)
    "a2a": {
      "port": 10000,
      "host": "0.0.0.0",
      "enabled": true,
      "agentCardPath": "/.well-known/agent.json",
      "cors": {
        "origins": ["*"],
        "methods": ["GET", "POST", "OPTIONS"],
        "headers": ["Content-Type", "Authorization", "X-API-Key"]
      }
    },

    // coms-net configuration (internal fleet communication)
    "comsNet": {
      "hubUrl": "http://192.168.0.142:8080",
      "project": "lab",
      "authToken": "lab-fleet-2026",
      "agentName": "a2a-gateway",
      "heartbeatMs": 10000
    },

    // Task state mapping: coms-net → A2A
    "stateMapping": {
      "queued": "submitted",
      "delivered": "working",
      "complete": "completed",
      "error": "failed",
      "timeout": "failed",
      "stale": "failed"
    },

    // A2A → coms-net translation rules
    "translation": {
      // When an A2A agent sends a message, translate to coms_net_send
      "messageSend": {
        "action": "coms_net_send",
        "mapMessage": true,
        "mapPartsToPrompt": true
      },
      // When coms-net delivers a response, translate to A2A Task
      "responseToTask": {
        "mapStatus": true,
        "mapResponseToArtifact": true
      }
    },

    // Security
    "security": {
      "type": "bearer",
      "token": "lab-fleet-2026"
    },

    // Fleet node registry (generated by scripts/generate-agent-cards.ts)
    "fleetRegistry": "~/.pi/agent/a2a/agents/fleet-registry.json",

    // Logging
    "logging": {
      "level": "info",
      "auditChannel": "a2a-gateway-log"
    }
  }
}
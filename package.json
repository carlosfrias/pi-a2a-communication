{
  "name": "pi-a2a-communication",
  "version": "0.6.0",
  "description": "Enterprise-grade A2A (Agent2Agent) protocol implementation for pi coding agent - enables multi-node, multi-agent collaboration across enterprise environments",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run build:cjs",
    "build:cjs": "tsc -p tsconfig.cjs.json && mv dist/cjs/index.js dist/index.cjs",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "lint": "eslint . --ext .ts",
    "test": "vitest",
    "test:build": "bash scripts/test-prod-build.sh"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package",
    "a2a",
    "agent2agent",
    "multi-agent",
    "distributed",
    "enterprise",
    "agent-protocol",
    "orchestration",
    "google-a2a",
    "agent-collaboration"
  ],
  "author": "pi-extensions <extensions@pi.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlosfrias/pi-a2a-communication.git"
  },
  "bugs": {
    "url": "https://github.com/carlosfrias/pi-a2a-communication/issues"
  },
  "homepage": "https://github.com/carlosfrias/pi-a2a-communication#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "vitest": "^1.6.1"
  }
}

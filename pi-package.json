{
  "name": "pi-a2a-gateway",
  "version": "0.1.0-alpha.1",
  "description": "A2A gateway for pi — forked from pi-a2a-communication, adding spec compliance, streaming, and coms-net bridge",
  "author": "Carlos Frias <carlos@frias.io>",
  "contributors": ["DrOlu/pi-a2a-communication (original)"],
  "license": "MIT",
  "category": "communication",
  "tags": ["a2a", "multi-agent", "distributed", "gateway", "coms-net-bridge"],
  "repository": "https://github.com/carlosfrias/pi-a2a-gateway",
  "compatibility": {
    "pi": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "commands": [
    "/a2a-discover",
    "/a2a-agents",
    "/a2a-send",
    "/a2a-broadcast",
    "/a2a-chain",
    "/a2a-status",
    "/a2a-cancel",
    "/a2a-server",
    "/a2a-config",
    "/a2a-help"
  ],
  "tools": ["a2a_call", "a2a_parallel"],
  "changes": [
    "Forked from pi-a2a-communication v1.0.1",
    "Renamed to pi-a2a-gateway",
    "Adding TDD test suite",
    "A2A v1.0 spec compliance fixes (JSON-RPC methods, agent-card path)",
    "Adding SendStreamingMessage SSE support",
    "Adding push notification support",
    "Adding coms-net bridge layer"
  ]
}
{
  "name": "pi-a2a-communication",
  "version": "0.7.0",
  "description": "A2A client extension for pi \u2014 provides slash commands and tools for A2A v1.0 protocol communication plus autonomous fleet health monitoring",
  "author": "Carlos Frias <carlos@frias.io>",
  "contributors": [
    "DrOlu/pi-a2a-communication (original)"
  ],
  "license": "MIT",
  "category": "communication",
  "tags": [
    "a2a",
    "multi-agent",
    "distributed",
    "communication",
    "pi-extension",
    "fleet",
    "health-monitor",
    "self-healing"
  ],
  "repository": "https://github.com/carlosfrias/pi-a2a-communication",
  "compatibility": {
    "pi": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "commands": [
    "/a2a-discover",
    "/a2a-agents",
    "/a2a-send",
    "/a2a-broadcast",
    "/a2a-chain",
    "/a2a-status",
    "/a2a-cancel",
    "/a2a-server",
    "/a2a-config",
    "/a2a-help",
    "/fleet-health-status",
    "/fleet-remediate"
  ],
  "tools": [
    "a2a_call",
    "a2a_parallel",
    "a2a_chain"
  ],
  "changes": [
    "Forked from pi-a2a-communication v1.0.1",
    "Renamed to pi-a2a-communication (client extension identity)",
    "Adding TDD test suite",
    "A2A v1.0 spec compliance fixes (JSON-RPC methods, agent-card path)",
    "Adding SendStreamingMessage SSE support",
    "Adding push notification support",
    "Autonomous fleet health monitoring with node reporter + orchestrator remediation loop",
    "Self-healing systemd units: pi-agent boot guard + health reporter timer"
  ]
}
